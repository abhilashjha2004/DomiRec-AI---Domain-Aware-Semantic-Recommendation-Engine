# Virtual Environment
venv/
.venv/
env/

# Node modules and build distributions
node_modules/
dist/
build/

# Python caching
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment variables — exclude secrets, keep dev env files
.env
.env.local
.env.production
.env.*.local

# Editor / IDE configuration
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Log files
*.log
logs/

# Offline FAISS index temporary files (legacy path — not used)
ml/faiss_indexes/*.index

# Explicitly track prebuilt FAISS indexes and embeddings cache so Render
# can use the fast startup path without rebuilding on every deploy.
!data/embeddings/*.faiss
!data/embeddings/*.pkl
